{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Proxy",
  "version": "0.1.0",
  "identifier": "app.proxy.desktop",
  "build": {
    "frontendDist": "../../frontend/dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "npm run dev:tauri-stack",
    "beforeBuildCommand": "npm run tauri:prebuild"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Proxy",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "url": "http://127.0.0.1:9091"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../../frontend/dist": "dist"
    },
    "externalBin": ["binaries/proxy-app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
